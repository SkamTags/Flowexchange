# Токен бота от @BotFather
BOT_TOKEN=123456789:ABCdefGHI...

# Канал: @username канала или ID (например -1001234567890)
# Бот должен быть администратором канала с правом публикации сообщений
CHANNEL=@Fl0wExchange

# Опционально: мин. сумма сделки в сообщении (по умолчанию "20 000")
# MIN_DEAL_AMOUNT=20 000

# Опционально: контакт в сообщении (по умолчанию @Fl0wExchange)
# CONTACT=@Fl0wExchange
